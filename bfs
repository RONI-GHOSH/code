#include <stdio.h>

int queue[10];
int front = 0, rear = 0;

void enqueue(int x)
{
    queue[rear++] = x;
}

int dequeue()
{
    return queue[front++];
}

int main()
{
    int n, graph[10][10], visited[10] = {0};
    int i, j, start, v;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");
    for(i = 0; i < n; i++)
        for(j = 0; j < n; j++)
            scanf("%d", &graph[i][j]);

    printf("Enter starting vertex: ");
    scanf("%d", &start);

    visited[start] = 1;
    enqueue(start);

    printf("BFS Traversal: ");

    while(front < rear)
    {
        v = dequeue();
        printf("%d ", v);

        for(i = 0; i < n; i++)
        {
            if(graph[v][i] == 1 && visited[i] == 0)
            {
                visited[i] = 1;
                enqueue(i);
            }
        }
    }

    return 0;
}

