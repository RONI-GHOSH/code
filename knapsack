#include <stdio.h>

int main() {
    int n, i, j;
    float w[10], p[10], ratio[10], capacity;
    float totalProfit = 0, temp;

    printf("Enter number of items: ");
    scanf("%d", &n);

    printf("Enter profit and weight of each item:\n");
    for(i = 0; i < n; i++) {
        scanf("%f %f", &p[i], &w[i]);
        ratio[i] = p[i] / w[i];
    }

    printf("Enter knapsack capacity: ");
    scanf("%f", &capacity);

    // Sort by profit/weight ratio (descending)
    for(i = 0; i < n - 1; i++) {
        for(j = i + 1; j < n; j++) {
            if(ratio[i] < ratio[j]) {

                temp = ratio[i];
                ratio[i] = ratio[j];
                ratio[j] = temp;

                temp = p[i];
                p[i] = p[j];
                p[j] = temp;

                temp = w[i];
                w[i] = w[j];
                w[j] = temp;
            }
        }
    }

    for(i = 0; i < n; i++) {
        if(w[i] <= capacity) {
            capacity -= w[i];
            totalProfit += p[i];
        } else {
            totalProfit += p[i] * (capacity / w[i]);
            break;
        }
    }

    printf("Maximum Profit = %.2f\n", totalProfit);

    return 0;
}

